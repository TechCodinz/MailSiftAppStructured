MAILSIFT_SECRET=change-me-strong-secret
MAILSIFT_ADMIN_KEY=change-me-admin-key

# Pricing and gating
PRICE_USDT=30
FREE_SCRAPE_LIMIT=3

# Crypto wallets
MAILSIFT_RECEIVE_ADDRESS=TRX_OR_TRC20_USDT_ADDRESS
WALLET_BTC=
WALLET_ETH=

# SMTP for license delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# TronGrid API (optional for auto-verify)
TRONGRID_KEY=
TRONGRID_BASE=https://api.trongrid.io

# Optional: override payments file path
MAILSIFT_PAYMENTS_FILE=/data/payments.json
