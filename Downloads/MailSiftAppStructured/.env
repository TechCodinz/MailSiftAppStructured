MAILSIFT_SECRET=change-me-strong-secret
MAILSIFT_ADMIN_KEY=change-me-admin
FREE_SCRAPE_QUOTA=3
SESSION_COOKIE_SECURE=true
ENVIRONMENT=production
GLOBAL_RATE_LIMIT=120 per minute
SCRAPE_RATE_LIMIT=20/minute
PAY_RATE_LIMIT=5/minute
ADMIN_RATE_LIMIT=60/minute
RATELIMIT_STORAGE_URI=redis://redis:6379/0
MAILSIFT_SQLITE_DB=/data/mailsift.db
MAILSIFT_WALLET_BTC=bc1q...
MAILSIFT_WALLET_TRC20=TX...
MAILSIFT_WALLET_ETH=0x...
MAILSIFT_RECEIVE_ADDRESS=TX...
TRONGRID_BASE=https://api.trongrid.io
TRONGRID_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@mailsift.app
SENTRY_DSN=
SENTRY_TRACES=0.0
ADMIN_IP_ALLOWLIST=